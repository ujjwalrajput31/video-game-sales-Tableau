      </column>
      <column caption='Sales Category' datatype='string' name='[Calculation_1631127786151938]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [total_sales] &gt; 5 THEN &quot;Blockbuster&quot;&#13;&#10;ELSEIF [total_sales] &gt; 1 THEN &quot;Hit&quot;&#13;&#10;ELSE &quot;Average&quot;&#13;&#10;END' />
      </column>
      <column caption='Regional Total' datatype='real' name='[Calculation_1631127800045571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[na_sales] + [pal_sales] + [jp_sales] + [other_sales]' />
      </column>
