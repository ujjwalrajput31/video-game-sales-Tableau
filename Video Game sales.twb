      <column caption='Top Publisher Filter' datatype='boolean' name='[Calculation_1631127760375808]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([total_sales])) &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
